{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "module": "ESNext",
        "types": ["node"],
        "lib": ["ESNext", "DOM"],
        "target": "ES2020",
        "moduleResolution": "bundler",
        "allowJs": false,
        "strict": true,
        "esModuleInterop": true,
        "declaration": true,
        "declarationDir": "dist/types"
    },
    "include": ["src"]
}