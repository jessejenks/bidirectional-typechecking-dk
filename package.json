    "@types/node": "25.6.0",
    "c8": "11.0.0",
    "rollup": "4.60.2",
    "tslib": "2.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@jessejenks/ts-combinator": "3.3.0"
  }
